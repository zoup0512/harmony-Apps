# HarmonyOS .gitignore
.idea/
.ohos/
.hvigor/
*.iml
*.iws
*.ipr
modules.xml
compiler.xml
navigation.xml
build/
out/
cache/
generated/
hvigor-build/
oh-build/
entry/build/
feature/build/
*/build/
*/oh-build/
.cxx/
oh_modules/
node_modules/
local.properties
signing.properties
*.p12
*.jks
*.keystore
secret.key
# Whitelist committed debug signing materials for the main module
!app/sign/debug/*.p12
!app/sign/debug/*.jks
!app/sign/debug/*.keystore
!app/sign/debug/signing.properties
*.log
*.tmp
*.dump
lint-report*
build-log*
package-lock.json
yarn.lock
.DS_Store
Thumbs.db
*.swp
*.swo
