{
  "app": {
    "signingConfigs": [
      {
        "name": "default",
        "type": "HarmonyOS",
        "material": {
          "certpath": "app/sign/debug/Apps.cer",
          "keyAlias": "debugkey",
          "keyPassword": "x121169225",
          "profile": "app/sign/debug/AppsDebug.p7b",
          "signAlg": "SHA256withECDSA",
          "storeFile": "app/sign/debug/Apps.p12",
          "storePassword": "x121169225"
        }
      }
    ],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "6.0.2(22)",
